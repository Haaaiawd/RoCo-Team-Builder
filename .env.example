# RoCo Team Builder - Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# LLM Provider Configuration
# ============================================

# Provider model to use (e.g., gpt-4o, claude-3-opus)
ROCO_PROVIDER_MODEL=gpt-4o

# Provider base URL (default: OpenRouter)
ROCO_PROVIDER_BASE_URL=https://openrouter.ai/api/v1

# Provider API key (required for agent-backend-system)
# Get your API key from: https://openrouter.ai/keys
ROCO_PROVIDER_API_KEY=your_openrouter_api_key_here

# ============================================
# Agent Backend Configuration
# ============================================

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Server host (default: 0.0.0.0)
HOST=0.0.0.0

# Server port (default: 8000)
PORT=8000

# ============================================
# Web UI Configuration
# ============================================

# Enable Direct Connections (BYOK)
ENABLE_DIRECT_CONNECTIONS=true

# Default models for Web UI
DEFAULT_MODELS=gpt-4o

# ============================================
# Optional: Development Configuration
# ============================================

# Enable debug mode (default: false)
DEBUG=false

# Enable auto-reload for development (default: false)
RELOAD=false

# ============================================
# Notes:
# ============================================
# - ROCO_PROVIDER_API_KEY is required for the agent-backend-system to function
# - For BYOK, users will provide their own API keys in the Web UI
# - The built-in route uses the ROCO_PROVIDER_API_KEY configured above
# - BYOK route connects directly to user-configured providers
